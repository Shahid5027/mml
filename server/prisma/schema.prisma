datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum PunchType {
  CHECK_IN
  CHECK_OUT
}

model User {
  id               String              @id @default(uuid())
  name             String
  email            String              @unique
  passwordHash     String
  role             Role                @default(EMPLOYEE)
  department       String?
  shiftStartTime   String              @default("09:00") // Format "HH:MM"
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  
  attendances      Attendance[]
  logs             AttendanceLog[]
  insights         AttendanceInsight[]

  @@index([email])
}

model OfficeSettings {
  id                   String   @id @default(uuid())
  latitude             Float
  longitude            Float
  radiusMeters         Float    @default(100.0)
  lateThresholdMinutes Int      @default(15)
  updatedAt            DateTime @updatedAt
}

model Attendance {
  id           String    @id @default(uuid())
  userId       String
  date         DateTime  @db.Date
  checkInTime  DateTime
  checkInLat   Float
  checkInLng   Float
  checkOutTime DateTime?
  checkOutLat  Float?
  checkOutLng  Float?
  workingHours Float?    @default(0.0)
  isLate       Boolean   @default(false)
  status       String    @default("PRESENT") // PRESENT, ABSENT, INVALID
  
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, date])
  @@index([userId, date])
}

model AttendanceLog {
  id                 String    @id @default(uuid())
  userId             String
  eventType          PunchType
  timestamp          DateTime  @default(now())
  lat                Float
  lng                Float
  distanceFromOffice Float
  accepted           Boolean   @default(true)
  reason             String?
  
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
}

model AttendanceInsight {
  id                   String   @id @default(uuid())
  userId               String
  date                 DateTime @db.Date
  confidenceScore      Int      @default(100)
  unusualLocation      Boolean  @default(false)
  unusualTiming        Boolean  @default(false)
  failedAttemptsCount  Int      @default(0)
  analysisDetails      String?
  
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}
